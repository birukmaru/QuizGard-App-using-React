# QuizGuard Docker Environment Variables
# Copy this file to .env and fill in the values

# PostgreSQL Configuration
POSTGRES_USER=quizguard
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=quizguard

# Node Environment
NODE_ENV=production

# Clerk Authentication
# Get these from https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Allowed Origins (comma-separated)
# Include your domain in production
ALLOWED_ORIGINS=http://localhost,https://your-domain.com
